{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Syncing permissions from .vscode/settings.example.json",
            "command": "python3 -c \"import json; s=json.load(open('.claude/settings.json')); e=json.load(open('.vscode/settings.example.json')); s['permissions']=e['permissions']; json.dump(s,open('.claude/settings.json','w'),indent=2)\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "~/git"
    ],
    "allow": [
      "Bash(git *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(west *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(make *)",
      "Bash(gh *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(.venv/bin/python *)",
      "Bash(../.venv/bin/python *)",
      "Bash(source *)",
      "Bash(bash *)",
      "Bash(arm-none-eabi-* *)",
      "Bash(gdb *)",
      "Bash(st-flash *)",
      "Bash(STM32_Programmer_CLI *)",
      "Bash(STLinkCLI *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(tio *)",
      "Bash(lsusb *)",
      "Bash(lsusb)",
      "Bash(ls /dev/serial/*)",
      "Bash(ls /dev/ttyACM*)",
      "Bash(ls /dev/tty*)",
      "Bash(stty -F *)",
      "Bash(cat /dev/tty*)",
      "Bash(cat /dev/serial/*)",
      "Bash(fuser *)",
      "Bash(udevadm *)",
      "Bash(dmesg *)",
      "Bash(journalctl *)",
      "Bash(ip *)",
      "Bash(ping *)",
      "Bash(arp *)",
      "Bash(arping *)",
      "Bash(nmcli *)",
      "Bash(tcpdump *)",
      "Bash(candump *)",
      "Bash(cansend *)",
      "Bash(sysctl *)",
      "Bash(pgrep *)",
      "Bash(pkill *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ps *)",
      "Bash(jobs *)",
      "Bash(tmux *)",
      "Bash(wmctrl *)",
      "Bash(chmod *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(wc *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(find *)",
      "Bash(tee *)",
      "Bash(unzip *)",
      "Bash(strings *)",
      "Bash(xargs *)",
      "Bash(timeout *)",
      "Bash(scripts/* *)",
      "Bash(tools/* *)"
    ]
  }
}
